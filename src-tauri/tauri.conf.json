{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orion Terminal",
  "version": "0.1.0",
  "identifier": "com.lucaorion.orion-terminal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orion Terminal",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/assets/**",
          "$APPDATA/com.lucaorion.orion-terminal/assets/**",
          "$APPDATA/wallpapers/**",
          "$APPDATA/com.lucaorion.orion-terminal/wallpapers/**",
          "$APPDATA/repolens/**",
          "$APPDATA/com.lucaorion.orion-terminal/repolens/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../resources/website-cloner-scaffold"]
  }
}
